#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMPOSE_TEMPLATE="${COMPOSE_TEMPLATE:-$APP_ROOT/compose.example.yml}"
COMPOSE_FILE="${COMPOSE_FILE:-$APP_ROOT/compose.yml}"
ENV_FILE="${ENV_FILE:-$APP_ROOT/.env.docker}"

RECONFIGURE=false
SETUP_ONLY=false
PULL=false
COMPOSE_ARGS=(up -d)

usage() {
  cat <<'USAGE'
Usage: bin/docker-up [options] [-- compose args...]

Creates a local Docker Compose setup from compose.example.yml, prompts for a
PostgreSQL password during setup, then starts Sure with Docker Compose.

Options:
  --reconfigure   Prompt for settings again and rewrite .env.docker.
  --foreground    Run "docker compose up" instead of "docker compose up -d".
  --pull          Pull images before starting containers.
  --setup-only    Create compose/env files without starting containers.
  -h, --help      Show this help.

Examples:
  bin/docker-up
  bin/docker-up --reconfigure
  bin/docker-up --foreground
  bin/docker-up -- ps
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --reconfigure)
      RECONFIGURE=true
      shift
      ;;
    --foreground)
      COMPOSE_ARGS=(up)
      shift
      ;;
    --pull)
      PULL=true
      shift
      ;;
    --setup-only)
      SETUP_ONLY=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      if [[ $# -gt 0 ]]; then
        COMPOSE_ARGS=("$@")
      fi
      break
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

generate_secret() {
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 64
  else
    head -c 64 /dev/urandom | od -An -tx1 | tr -d ' \n'
    echo
  fi
}

generate_password() {
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -base64 32 | tr -d '\n'
    echo
  else
    head -c 32 /dev/urandom | base64 | tr -d '\n'
    echo
  fi
}

dotenv_quote() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\'/\\\'}"
  printf "'%s'" "$value"
}

env_has_key() {
  local key="$1"
  [[ -f "$ENV_FILE" ]] && grep -Eq "^[[:space:]]*${key}=" "$ENV_FILE"
}

write_env_file() {
  local postgres_user="$1"
  local postgres_password="$2"
  local postgres_db="$3"
  local secret_key_base="$4"
  local port="$5"

  umask 077
  {
    echo "# Generated by bin/docker-up."
    echo "# This file is used with: docker compose --env-file .env.docker"
    echo "POSTGRES_USER=$(dotenv_quote "$postgres_user")"
    echo "POSTGRES_PASSWORD=$(dotenv_quote "$postgres_password")"
    echo "POSTGRES_DB=$(dotenv_quote "$postgres_db")"
    echo "SECRET_KEY_BASE=$(dotenv_quote "$secret_key_base")"
    echo "PORT=$(dotenv_quote "$port")"
    echo "OPENAI_ACCESS_TOKEN="
  } > "$ENV_FILE"
}

prompt_value() {
  local prompt="$1"
  local default_value="$2"
  local value

  read -r -p "$prompt [$default_value]: " value
  printf '%s' "${value:-$default_value}"
}

prompt_password() {
  local password confirmation

  while true; do
    read -r -s -p "PostgreSQL password (leave blank to generate one): " password
    echo

    if [[ -z "$password" ]]; then
      generate_password
      return
    fi

    read -r -s -p "Confirm PostgreSQL password: " confirmation
    echo

    if [[ "$password" == "$confirmation" ]]; then
      printf '%s' "$password"
      return
    fi

    echo "Passwords did not match. Try again."
  done
}

create_compose_file() {
  if [[ -f "$COMPOSE_FILE" ]]; then
    echo "Using existing $(basename "$COMPOSE_FILE")."
    return
  fi

  if [[ ! -f "$COMPOSE_TEMPLATE" ]]; then
    echo "Missing compose template: $COMPOSE_TEMPLATE" >&2
    exit 1
  fi

  cp "$COMPOSE_TEMPLATE" "$COMPOSE_FILE"
  echo "Created $(basename "$COMPOSE_FILE") from $(basename "$COMPOSE_TEMPLATE")."
}

create_env_file() {
  local needs_setup=false

  if [[ ! -f "$ENV_FILE" ]] || [[ "$RECONFIGURE" == true ]]; then
    needs_setup=true
  elif ! env_has_key POSTGRES_PASSWORD || ! env_has_key SECRET_KEY_BASE; then
    needs_setup=true
  fi

  if [[ "$needs_setup" != true ]]; then
    echo "Using existing $(basename "$ENV_FILE")."
    return
  fi

  echo "Configuring Docker environment in $(basename "$ENV_FILE")."
  local postgres_user postgres_password postgres_db secret_key_base port
  postgres_user="$(prompt_value "PostgreSQL user" "sure_user")"
  postgres_db="$(prompt_value "PostgreSQL database" "sure_production")"
  port="$(prompt_value "Host port" "3000")"
  postgres_password="$(prompt_password)"
  secret_key_base="$(generate_secret)"

  write_env_file "$postgres_user" "$postgres_password" "$postgres_db" "$secret_key_base" "$port"
  echo "Wrote $(basename "$ENV_FILE")."
}

run_compose() {
  local compose=(docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE")

  if [[ "$PULL" == true ]]; then
    "${compose[@]}" pull
  fi

  if [[ "$SETUP_ONLY" == true ]]; then
    echo "Setup complete. Start containers with: bin/docker-up"
    return
  fi

  "${compose[@]}" "${COMPOSE_ARGS[@]}"
}

require_command docker
docker compose version >/dev/null

cd "$APP_ROOT"
create_compose_file
create_env_file
run_compose
