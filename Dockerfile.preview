FROM busybox:1.36.1-musl

RUN mkdir -p /www/sessions \
    && cat > /www/index.html <<'EOF'
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Sure Preview Hello World</title>
  </head>
  <body>
    <h1>Sure Preview Hello World</h1>
    <p>If you can read this, the Cloudflare container + proxy path is alive.</p>
  </body>
</html>
EOF
RUN printf 'ok\n' > /www/up \
    && cp /www/index.html /www/sessions/new

EXPOSE 3000
CMD ["httpd", "-f", "-p", "3000", "-h", "/www"]
