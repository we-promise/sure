<%= render DS::Popover.new(variant: :button, placement: "bottom-end") do |popover| %>
  <% popover.with_button(
       class: "inline-flex items-center gap-1.5 #{ filtered? ? "bg-inverse text-inverse border-inverse" : "bg-container border-secondary text-primary" } border font-medium rounded-lg pl-3 pr-2 py-2 text-sm cursor-pointer hover:opacity-90 focus-ring",
       aria: { label: t(".aria_label", default: "Filter by account") }
     ) do %>
    <%= helpers.icon("bar-chart-2", size: "sm") %>
    <span class="whitespace-nowrap"><%= trigger_label %></span>
    <%= helpers.icon("chevron-down", size: "sm") %>
  <% end %>

  <% popover.with_custom_content do %>
    <div class="p-3 min-w-[220px]">
      <p class="text-xs font-semibold text-secondary uppercase tracking-wide mb-2 px-1">
        <%= t(".accounts_label", default: "Accounts") %>
      </p>

      <%= form_with url: url, method: :get, data: { controller: "auto-submit-form" } do |f| %>
        <%# Preserve any extra params (e.g. period, period_type, dates) %>
        <% extra_params.each do |key, value| %>
          <% Array(value).compact.each do |v| %>
            <%= hidden_field_tag key, v %>
          <% end %>
        <% end %>

        <div class="space-y-1 max-h-64 overflow-y-auto">
          <% grouped_accounts.each do |accountable_type, group| %>
            <p class="text-xs text-subdued font-medium px-1 pt-2 first:pt-0"><%= group_label(accountable_type) %></p>
            <% group.each do |account| %>
              <label class="flex items-center gap-2 px-1 py-1 rounded-md hover:bg-surface-hover cursor-pointer text-sm text-primary">
                <%= check_box_tag "account_ids[]", account.id, selected?(account),
                      data: { auto_submit_form_target: "auto" },
                      class: "rounded border-secondary accent-accent",
                      id: "account_filter_#{account.id}" %>
                <span class="truncate"><%= account.name %></span>
              </label>
            <% end %>
          <% end %>
        </div>

        <% if filtered? %>
          <div class="mt-2 pt-2 border-t border-primary">
            <%= link_to t(".clear_filter", default: "Clear filter"),
                  clear_url,
                  class: "text-xs text-secondary hover:text-primary" %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>
