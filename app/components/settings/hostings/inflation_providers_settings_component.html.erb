<div class="space-y-4">
  <%= form_with model: Setting.new,
                builder: StyledFormBuilder,
                url: settings_hosting_path,
                method: :patch,
                data: {
                  controller: "auto-submit-form",
                  "auto-submit-form-trigger-event-value": "blur"
                } do |form| %>
    <div class="space-y-5">
      <div class="space-y-2">
        <p class="font-medium"><%= t("settings.hostings.inflation_providers_settings.us_bls_title") %></p>
        <p class="text-xs text-secondary"><%= t("settings.hostings.inflation_providers_settings.us_bls_hint") %></p>

        <% if us_bls_base_url_locked? %>
          <p class="text-xs text-secondary"><%= t("settings.hostings.inflation_providers_settings.locked_by_env", var: "US_BLS_CPI_BASE_URL") %></p>
        <% end %>
        <%= form.text_field :us_bls_cpi_base_url,
                            label: t("settings.hostings.inflation_providers_settings.base_url"),
                            value: us_bls_base_url_effective,
                            disabled: us_bls_base_url_locked?,
                            placeholder: "https://api.bls.gov/publicAPI/v2",
                            data: { "auto-submit-form-target": "auto" } %>

        <% if us_bls_series_id_locked? %>
          <p class="text-xs text-secondary"><%= t("settings.hostings.inflation_providers_settings.locked_by_env", var: "US_BLS_CPI_SERIES_ID") %></p>
        <% end %>
        <%= form.text_field :us_bls_cpi_series_id,
                            label: t("settings.hostings.inflation_providers_settings.series_id"),
                            value: us_bls_series_id_effective,
                            disabled: us_bls_series_id_locked?,
                            placeholder: "CUUR0000SA0",
                            data: { "auto-submit-form-target": "auto" } %>
      </div>

      <div class="space-y-2">
        <p class="font-medium"><%= t("settings.hostings.inflation_providers_settings.es_ine_title") %></p>
        <p class="text-xs text-secondary"><%= t("settings.hostings.inflation_providers_settings.es_ine_hint") %></p>

        <% if es_ine_base_url_locked? %>
          <p class="text-xs text-secondary"><%= t("settings.hostings.inflation_providers_settings.locked_by_env", var: "ES_INE_CPI_BASE_URL") %></p>
        <% end %>
        <%= form.text_field :es_ine_cpi_base_url,
                            label: t("settings.hostings.inflation_providers_settings.base_url"),
                            value: es_ine_base_url_effective,
                            disabled: es_ine_base_url_locked?,
                            placeholder: "https://servicios.ine.es/wstempus/js/EN/DATOS_SERIE/",
                            data: { "auto-submit-form-target": "auto" } %>

        <% if es_ine_series_id_locked? %>
          <p class="text-xs text-secondary"><%= t("settings.hostings.inflation_providers_settings.locked_by_env", var: "ES_INE_CPI_SERIES_ID") %></p>
        <% end %>
        <%= form.text_field :es_ine_cpi_series_id,
                            label: t("settings.hostings.inflation_providers_settings.series_id"),
                            value: es_ine_series_id_effective,
                            disabled: es_ine_series_id_locked?,
                            placeholder: t("settings.hostings.inflation_providers_settings.es_ine_series_placeholder"),
                            data: { "auto-submit-form-target": "auto" } %>
      </div>
    </div>
  <% end %>
</div>
