<div class="space-y-4">
  <p class="text-secondary text-sm"><%= t("settings.hostings.inflation_settings.import_description") %></p>

  <%= form_with model: Setting.new,
                builder: StyledFormBuilder,
                url: settings_hosting_path,
                method: :patch,
                data: {
                  controller: "auto-submit-form",
                  "auto-submit-form-trigger-event-value": "change"
                } do |form| %>
    <div class="flex items-center justify-between gap-4">
      <div class="space-y-1">
        <p class="text-sm"><%= t("settings.hostings.inflation_settings.import_enabled_label") %></p>
        <p class="text-secondary text-sm"><%= t("settings.hostings.inflation_settings.import_enabled_help") %></p>
      </div>

      <%= form.toggle :inflation_import_enabled,
                      checked: inflation_import_enabled_effective,
                      disabled: import_toggle_locked_by_env?,
                      data: { auto_submit_form_target: "auto" } %>
    </div>
    <% if import_toggle_locked_by_env? %>
      <p class="text-xs text-secondary mt-1"><%= t("settings.hostings.inflation_settings.import_enabled_env_locked") %></p>
    <% end %>
  <% end %>

  <% unless inflation_import_enabled_effective %>
    <%= form_with model: Setting.new,
                  builder: StyledFormBuilder,
                  url: import_inflation_rates_settings_hosting_path,
                  method: :post do |form| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <%= form.number_field :inflation_start_year,
                              label: t("settings.hostings.inflation_settings.start_year"),
                              value: start_year_default,
                              min: 1990,
                              max: current_year %>
        <%= form.number_field :inflation_end_year,
                              label: t("settings.hostings.inflation_settings.end_year"),
                              value: end_year_default,
                              min: 1990,
                              max: current_year %>
      </div>

      <div class="mt-3">
        <%= form.submit t("settings.hostings.inflation_settings.import_now") %>
      </div>
    <% end %>
  <% end %>

  <details class="group">
    <summary class="flex items-center justify-between cursor-pointer list-none">
      <div class="space-y-0.5">
        <p class="text-sm font-medium">
          <strong><%= t("settings.hostings.inflation_settings.last_import") %>:</strong>
          <%= last_import_at.present? ? l(last_import_at, format: :long) : t("settings.hostings.inflation_settings.never") %>
        </p>
        <% if last_import_error.present? %>
          <p class="text-xs text-destructive"><%= last_import_error %></p>
        <% end %>
      </div>
      <%= helpers.icon("chevron-right", class: "w-4 h-4 text-secondary transition-transform group-open:rotate-90") %>
    </summary>

    <div class="mt-3 space-y-1 text-sm text-secondary">
      <% if last_import_range.present? %>
        <p><strong><%= t("settings.hostings.inflation_settings.last_range") %>:</strong> <%= last_import_range %></p>
      <% end %>
      <% if last_import_count.present? %>
        <p><strong><%= t("settings.hostings.inflation_settings.last_count") %>:</strong> <%= last_import_count %></p>
      <% end %>
    </div>

    <div class="mt-3 pt-3 border-t border-primary space-y-3">
      <% provider_rows.each do |provider| %>
        <div class="space-y-0.5 text-sm text-secondary">
          <p class="font-medium text-primary"><%= provider[:title] %></p>
          <p><strong><%= t("settings.hostings.inflation_settings.last_count") %>:</strong> <%= value_or_dash(provider[:imported_count]) %></p>
          <p><strong><%= t("settings.hostings.inflation_settings.stored_records") %>:</strong> <%= provider[:stored_count] %></p>
          <p><strong><%= t("settings.hostings.inflation_settings.stored_range") %>:</strong> <%= value_or_dash(provider[:stored_range]) %></p>
        </div>
      <% end %>
    </div>
  </details>
</div>
