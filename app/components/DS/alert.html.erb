<div class="<%= container_classes %>">
  <% if title.present? %>
    <div class="flex items-center gap-3">
      <%= helpers.icon icon_name, size: "md", color: icon_color, class: "shrink-0" %>
      <p class="text-sm font-medium text-primary flex-1 leading-5"><%= title %></p>
    </div>

    <% if content.present? || message.present? %>
      <div class="text-sm text-primary mt-2 pl-8 space-y-1">
        <% if content.present? %>
          <%= content %>
        <% else %>
          <%= message %>
        <% end %>
      </div>
    <% end %>
  <% elsif content.present? %>
    <div class="flex items-start gap-3">
      <%= helpers.icon icon_name, size: "md", color: icon_color, class: "shrink-0 mt-0.5" %>
      <div class="flex-1 text-sm text-primary space-y-1">
        <%= content %>
      </div>
    </div>
  <% elsif message.present? %>
    <div class="flex items-center gap-3">
      <%= helpers.icon icon_name, size: "md", color: icon_color, class: "shrink-0" %>
      <p class="text-sm text-primary flex-1 leading-5"><%= message %></p>
    </div>
  <% end %>
</div>
