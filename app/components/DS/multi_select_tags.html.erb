<%# locals: (form:, method:, tags:, selected_ids:, label:, disabled:, input_options:, dropdown_label:) %>

<div class="form-field">
  <div class="form-field__body">
    <% if label %>
      <%= form.label method, label, class: "form-field__label" %>
    <% end %>

    <div class="pt-2" data-controller="tag-picker">
      <%# Hidden checkboxes — one per tag, drive form submission and trigger refresh %>
      <% tags.each do |tag| %>
        <%= form.check_box method,
                           {
                             multiple: true,
                             class: "sr-only",
                             id: checkbox_id(tag),
                             checked: selected_ids.include?(tag.id.to_s),
                             disabled: disabled,
                             "data-tag-picker-target": "input",
                             "data-tag-id": tag.id,
                             "data-action": "change->tag-picker#refresh",
                             **input_options
                           },
                           tag.id,
                           nil %>
      <% end %>

      <%# Selected chips — click to deselect %>
      <div class="flex flex-wrap gap-2 mb-2">
        <% tags.each do |tag| %>
          <% tag_color = tag.color.presence || Tag::UNCATEGORIZED_COLOR %>
          <button type="button"
                  class="border text-sm font-medium px-3 py-1 rounded-full items-center gap-2 transition-opacity duration-150 hover:opacity-70 <%= selected_ids.include?(tag.id.to_s) ? "inline-flex" : "hidden" %> <%= "opacity-50 pointer-events-none" if disabled %>"
                  data-tag-picker-target="chip"
                  data-tag-id="<%= tag.id %>"
                  data-action="click->tag-picker#deselect"
                  <%= "disabled" if disabled %>
                  style="background-color: color-mix(in oklab, <%= tag_color %> 14%, transparent); border-color: color-mix(in oklab, <%= tag_color %> 28%, transparent); color: <%= tag_color %>">
            <span class="size-1.5 rounded-full" style="background-color: <%= tag_color %>"></span>
            <%= tag.name %>
          </button>
        <% end %>
      </div>

      <%# Candidate dropdown with inline search filter %>
      <details class="group" data-tag-picker-target="dropdown" data-action="toggle->tag-picker#handleDropdownToggle">
        <summary class="list-none form-field__input w-full cursor-pointer flex items-center justify-between">
          <span class="text-secondary"><%= dropdown_label %></span>
          <%= helpers.icon("chevron-down", class: "transition-transform duration-150 group-open:rotate-180") %>
        </summary>
        <div class="mt-2 border border-secondary rounded-lg bg-container-inset p-2">
          <div class="relative mb-2">
            <%= helpers.icon("search", class: "absolute left-2 top-1/2 -translate-y-1/2 text-secondary pointer-events-none") %>
            <input type="search"
                   autocomplete="off"
                   placeholder="<%= t("helpers.select.search_placeholder", default: "Search...") %>"
                   class="form-field__input w-full pl-8 py-1 text-sm"
                   data-tag-picker-target="search"
                   data-action="input->tag-picker#filterOptions">
          </div>
          <div class="max-h-44 overflow-auto flex flex-wrap gap-2">
            <% tags.each do |tag| %>
              <% tag_color = tag.color.presence || Tag::UNCATEGORIZED_COLOR %>
              <button type="button"
                      class="inline-flex rounded-md transition-opacity duration-150 hover:opacity-80 disabled:opacity-30 disabled:cursor-not-allowed disabled:pointer-events-none"
                      data-tag-picker-target="option"
                      data-tag-id="<%= tag.id %>"
                      data-tag-name="<%= tag.name.downcase %>"
                      data-action="click->tag-picker#select"
                      <%= "disabled" if disabled || selected_ids.include?(tag.id.to_s) %>>
                <span class="border text-sm font-medium px-3 py-1 rounded-full inline-flex items-center gap-2"
                      style="background-color: color-mix(in oklab, <%= tag_color %> 10%, transparent); border-color: color-mix(in oklab, <%= tag_color %> 20%, transparent); color: <%= tag_color %>">
                  <span class="size-1.5 rounded-full" style="background-color: <%= tag_color %>"></span>
                  <%= tag.name %>
                </span>
              </button>
            <% end %>
          </div>
        </div>
      </details>
    </div>
  </div>
</div>
