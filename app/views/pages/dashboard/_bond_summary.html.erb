<%# locals: (bond_accounts:, total_value:, total_return:, top_lots:, **args) %>

<% if bond_accounts.any? %>
  <div id="bond-summary" class="space-y-4">
    <div class="flex justify-between gap-4 px-4">
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <h2 class="text-lg font-medium"><%= t(".title") %></h2>
        </div>

        <p class="text-primary text-3xl font-medium privacy-sensitive">
          <%= format_money(Money.new(total_value, Current.family.currency)) %>
        </p>

        <div class="flex items-center gap-2 text-sm">
          <span class="text-secondary"><%= t(".total_return") %>:</span>
          <span class="font-medium privacy-sensitive <%= total_return.negative? ? "text-destructive" : "text-success" %>">
            <%= format_money(Money.new(total_return, Current.family.currency)) %>
          </span>
        </div>
      </div>
    </div>

    <% if top_lots.any? %>
      <div class="bg-container-inset rounded-xl p-1 mx-4 overflow-x-auto">
        <div class="rounded-lg shadow-border-xs bg-container overflow-hidden">
          <table class="w-full">
            <thead class="bg-container-inset uppercase text-xs font-medium text-secondary">
              <tr>
                <th scope="col" class="px-4 py-2 text-left"><%= t(".bond") %></th>
                <th scope="col" class="px-4 py-2 text-right"><%= t(".rate") %></th>
                <th scope="col" class="px-4 py-2 text-right"><%= t(".principal") %></th>
                <th scope="col" class="px-4 py-2 text-right"><%= t(".maturity") %></th>
                <th scope="col" class="px-4 py-2 text-right"><%= t(".total_return") %></th>
              </tr>
            </thead>
            <tbody>
              <% top_lots.each_with_index do |(account, lot), index| %>
                <%= render UI::Dashboard::BondSummaryRow.new(account:, lot:, show_border: index < top_lots.size - 1) %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
