<%# locals: (bond_accounts:, **args) %>

<% open_lots = bond_accounts.flat_map do |account|
     lots = account.bond&.bond_lots&.select(&:open?) || []
     lots.map { |lot| [ account, lot ] }
   end %>
<% total_value = bond_accounts.sum { |account| account.balance_money.exchange_to(Current.family.currency, fallback_rate: 1).amount } %>
<% total_return = open_lots.sum do |(account, lot)|
     Money.new(lot.total_return_amount, account.currency).exchange_to(Current.family.currency, fallback_rate: 1).amount
   end %>

<% if bond_accounts.any? %>
  <div id="bond-summary" class="space-y-4">
    <div class="flex justify-between gap-4 px-4">
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <h2 class="text-lg font-medium"><%= t(".title") %></h2>
        </div>

        <p class="text-primary text-3xl font-medium privacy-sensitive">
          <%= format_money(Money.new(total_value, Current.family.currency)) %>
        </p>

        <div class="flex items-center gap-2 text-sm">
          <span class="text-secondary"><%= t(".total_return") %>:</span>
          <span class="font-medium privacy-sensitive <%= total_return.negative? ? "text-destructive" : "text-success" %>">
            <%= format_money(Money.new(total_return, Current.family.currency)) %>
          </span>
        </div>
      </div>
    </div>

    <% top_lots = open_lots.sort_by { |(_, lot)| -lot.estimated_current_value.to_d }.first(5) %>
    <% if top_lots.any? %>
      <div class="bg-container-inset rounded-xl p-1 mx-4 overflow-x-auto">
        <div class="rounded-lg shadow-border-xs bg-container overflow-hidden">
          <div class="grid grid-cols-[4fr_2fr_2fr_2fr_2fr] bg-container-inset px-4 py-2 uppercase text-xs font-medium text-secondary">
            <div><%= t(".bond") %></div>
            <div class="text-right"><%= t(".rate") %></div>
            <div class="text-right"><%= t(".principal") %></div>
            <div class="text-right"><%= t(".maturity") %></div>
            <div class="text-right"><%= t(".total_return") %></div>
          </div>

          <% top_lots.each_with_index do |(account, lot), index| %>
            <% label = Bond.long_subtype_label_for(lot.subtype) || t("bonds.purchase_holding.unknown") %>
            <% total_return_amount = lot.total_return_amount %>
            <% total_return_label = t("bonds.purchase_holding.since_purchase") %>
            <% if total_return_amount.abs < 0.01 && lot.projected_total_return_amount.positive? %>
              <% total_return_amount = lot.projected_total_return_amount %>
              <% total_return_label = t("bonds.purchase_holding.projected_to_maturity") %>
            <% end %>
            <% total_return_class = total_return_amount.negative? ? "text-destructive" : "text-success" %>
            <% rate_text = if lot.inflation_linked?
              if lot.requires_rate_review?
                t("bonds.purchase_holding.update_needed")
              elsif lot.current_rate_percent.present?
                number_to_percentage(lot.current_rate_percent, precision: 3)
              else
                t("bonds.purchase_holding.unknown")
              end
            else
              lot.interest_rate.present? ? number_to_percentage(lot.interest_rate, precision: 3) : t("bonds.purchase_holding.unknown")
            end %>
            <% rate_meta = if lot.inflation_linked?
              lot.requires_rate_review? ?
                t("bonds.purchase_holding.pending_review") :
                if lot.current_inflation_source == "gus"
                  t("bonds.purchase_holding.inflation_meta_gus", inflation: number_to_percentage(lot.current_inflation_component_percent&.to_d || 0, precision: 3), margin: number_to_percentage(lot.current_margin_percent&.to_d || 0, precision: 3))
                else
                  t("bonds.purchase_holding.inflation_meta_manual", inflation: number_to_percentage(lot.current_inflation_component_percent&.to_d || 0, precision: 3), margin: number_to_percentage(lot.current_margin_percent&.to_d || 0, precision: 3))
                end
            else
              t("bonds.purchase_holding.bond_meta", rate_type: lot.rate_type&.titleize || t("bonds.purchase_holding.unknown"), coupon: lot.coupon_frequency&.humanize || t("bonds.purchase_holding.unknown"))
            end %>

            <div class="grid grid-cols-[4fr_2fr_2fr_2fr_2fr] items-center p-4 text-sm font-medium text-primary <%= index < top_lots.size - 1 ? "border-b border-divider" : "" %>">
              <div class="flex items-center gap-4">
                <%= render DS::FilledIcon.new(variant: :text, text: label, size: "md", rounded: true) %>
                <div class="space-y-0.5 min-w-0">
                  <%= link_to label, account_path(account, tab: "positions"), class: "truncate hover:underline" %>
                  <p class="text-xs text-secondary truncate"><%= t(".account_wrapper", account: account.name, wrapper: account.short_subtype_label) %></p>
                </div>
              </div>

              <div class="text-right">
                <p class="privacy-sensitive"><%= rate_text %></p>
                <p class="font-normal text-secondary"><%= rate_meta %></p>
              </div>

              <div class="text-right">
                <p class="privacy-sensitive"><%= format_money(Money.new(lot.amount, account.currency)) %></p>
                <p class="font-normal text-secondary"><%= t(".principal_term", term: t(".term_months", count: lot.term_months)) %></p>
              </div>

              <div class="text-right">
                <p class="privacy-sensitive"><%= lot.maturity_date ? l(lot.maturity_date) : t("bonds.purchase_holding.unknown") %></p>
                <p class="font-normal text-secondary"><%= t(".maturity_label") %></p>
              </div>

              <div class="text-right">
                <p class="privacy-sensitive <%= total_return_class %>"><%= format_money(Money.new(total_return_amount, account.currency)) %></p>
                <p class="font-normal text-secondary"><%= total_return_label %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>