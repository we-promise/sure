<%# locals: (budget:) %>

<% return unless budget.initialized? %>

<% unbudgeted_with_spending = ->(budget_category) { budget_category.display_budgeted_spending.to_d <= 0 && budget_category.actual_spending.to_d.positive? } %>
<% uncategorized_budget_category = budget.uncategorized_budget_category %>
<% all_category_groups = BudgetCategory::Group.for(budget.budget_categories) %>
<% unbudgeted_groups = all_category_groups.each_with_object([]) do |group, filtered_groups|
     visible_parent = unbudgeted_with_spending.call(group.budget_category)
     visible_subcategories = group.budget_subcategories.select { |budget_subcategory| unbudgeted_with_spending.call(budget_subcategory) }

     next unless visible_parent || visible_subcategories.any?

     filtered_groups << BudgetCategory::Group.new(group.budget_category, visible_subcategories)
   end %>
<% show_uncategorized = unbudgeted_with_spending.call(uncategorized_budget_category) %>
<% visible_category_count = unbudgeted_groups.sum { |group| (unbudgeted_with_spending.call(group.budget_category) ? 1 : 0) + group.budget_subcategories.count } + (show_uncategorized ? 1 : 0) %>

<% if visible_category_count.positive? %>
  <div class="w-full bg-container rounded-xl shadow-border-xs p-4">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-medium"><%= t("budgets.show.not_in_budget_categories.title") %></h2>
    </div>

    <div class="bg-container-inset rounded-xl p-1">
      <div>
        <div class="flex items-center gap-1.5 px-4 py-2 text-xs font-medium text-secondary uppercase">
          <p><%= t("budgets.show.not_in_budget_categories.short_title") %></p>
          <span class="text-subdued">&middot;</span>
          <p><%= visible_category_count %></p>

          <p class="ml-auto">Amount</p>
        </div>

        <div class="bg-container py-1 shadow-border-xs rounded-md">
          <% unbudgeted_groups.each do |group| %>
            <% if unbudgeted_with_spending.call(group.budget_category) %>
              <div class="py-2">
                <%= render "budget_categories/budget_category", budget_category: group.budget_category, show_budget_meta: false %>
              </div>
            <% end %>

            <% group.budget_subcategories.each do |budget_subcategory| %>
              <div class="py-2 w-full flex items-start">
                <div class="ml-8 pt-4 flex items-center justify-center text-subdued">
                  <%= icon "corner-down-right" %>
                </div>

                <%= render "budget_categories/budget_category", budget_category: budget_subcategory, show_budget_meta: false %>
              </div>
            <% end %>

            <%= render "shared/ruler" %>
          <% end %>

          <% if show_uncategorized %>
            <div class="py-2">
              <%= render "budget_categories/budget_category", budget_category: uncategorized_budget_category, show_budget_meta: false %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
