<div class="pb-12">
  <%= render "budgets/budget_header",
            budget: @budget,
            previous_budget: nil,
            next_budget: nil,
            latest_budget: nil %>

  <div class="space-y-6 max-w-3xl mx-auto">
    <div class="bg-container rounded-xl shadow-border-xs p-6 grid grid-cols-3 gap-6">
      <div>
        <p class="text-secondary text-xs uppercase tracking-wide">Monthly surplus</p>
        <p class="text-primary text-xl font-medium mt-1"><%= format_money @savings_summary.surplus_money %></p>
      </div>
      <div>
        <p class="text-secondary text-xs uppercase tracking-wide">Allocated to goals</p>
        <p class="text-primary text-xl font-medium mt-1"><%= format_money @savings_summary.allocated_money %></p>
      </div>
      <div>
        <p class="text-secondary text-xs uppercase tracking-wide">Available</p>
        <p class="text-primary text-xl font-medium mt-1"><%= format_money @savings_summary.available_money %></p>
      </div>
    </div>

    <div class="flex items-center justify-between gap-3 flex-wrap">
      <h2 class="text-primary text-lg font-medium">Active goals</h2>
      <div class="flex items-center gap-2">
        <%= render DS::Button.new(text: "View all", variant: "secondary", icon: "external-link", size: "sm",
              href: savings_goals_path) %>
        <%= render DS::Button.new(text: "New goal", variant: "secondary", icon: "plus", size: "sm",
              href: new_savings_goal_path) %>
        <%= render DS::Button.new(
              text: "Auto-fund this month",
              variant: "primary",
              icon: "zap",
              size: "sm",
              href: budget_savings_auto_fund_path(budget_month_year: Budget.date_to_param(@budget.start_date)),
              method: :post,
              confirm: CustomConfirm.new(
                title: "Auto-fund all active goals?",
                body: "We will create auto contributions from this month's surplus, capped per goal."
              )
            ) %>
      </div>
    </div>

    <% if @savings_summary.active_goals.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @savings_summary.active_goals.each do |goal| %>
          <%= render Savings::GoalCardComponent.new(goal: goal) %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-container rounded-xl shadow-border-xs p-8 text-center">
        <p class="text-primary font-medium">No active savings goals.</p>
        <p class="text-secondary text-sm mt-1">Create one to start earmarking money.</p>
      </div>
    <% end %>
  </div>
</div>
