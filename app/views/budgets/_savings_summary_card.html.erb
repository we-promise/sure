<%# locals: (budget:, summary:) %>

<%= content_tag :div, class: "w-full bg-container rounded-xl shadow-border-xs p-4" do %>
  <div class="flex items-center justify-between gap-3 flex-wrap mb-4">
    <h2 class="text-lg font-medium shrink-0">Savings goals</h2>
    <div class="flex items-center gap-2">
      <%= render DS::Link.new(
        text: "Manage",
        variant: "secondary",
        icon: "settings-2",
        size: "sm",
        href: savings_goals_path
      ) %>
      <%= render DS::Link.new(
        text: "New goal",
        variant: "primary",
        icon: "plus",
        size: "sm",
        href: new_savings_goal_path
      ) %>
      <% if summary.active_goals.any? && summary.surplus.to_d.positive? %>
        <%= render DS::Button.new(
          text: "Auto-fund this month",
          variant: "outline",
          icon: "zap",
          size: "sm",
          href: budget_savings_auto_fund_path(budget_month_year: Budget.date_to_param(budget.start_date)),
          method: :post,
          confirm: CustomConfirm.new(
            title: "Auto-fund all active goals?",
            body: "Creates an auto-source contribution per goal, capped by each goal's monthly target and the remaining surplus."
          )
        ) %>
      <% end %>
    </div>
  </div>

  <% if summary.active_goals.any? %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4 text-sm">
      <div class="bg-container-inset rounded-lg p-3">
        <p class="text-secondary text-xs uppercase tracking-wide">Monthly surplus</p>
        <p class="text-primary text-base font-medium mt-1"><%= format_money summary.surplus_money %></p>
      </div>
      <div class="bg-container-inset rounded-lg p-3">
        <p class="text-secondary text-xs uppercase tracking-wide">Allocated to goals</p>
        <p class="text-primary text-base font-medium mt-1"><%= format_money summary.allocated_money %></p>
      </div>
      <div class="bg-container-inset rounded-lg p-3">
        <p class="text-secondary text-xs uppercase tracking-wide">Available</p>
        <p class="text-primary text-base font-medium mt-1"><%= format_money summary.available_money %></p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
      <% summary.active_goals.first(3).each do |goal| %>
        <%= render Savings::GoalCardComponent.new(goal: goal) %>
      <% end %>
    </div>

    <% if summary.active_goals.size > 3 %>
      <div class="text-center mt-3">
        <%= render DS::Link.new(
          text: "View all #{summary.active_goals.size} goals",
          variant: "secondary",
          size: "sm",
          icon: "arrow-right",
          icon_position: "right",
          href: savings_goals_path
        ) %>
      </div>
    <% end %>
  <% else %>
    <div class="bg-container-inset rounded-lg p-6 text-center">
      <p class="text-primary font-medium text-sm">No active savings goals.</p>
      <p class="text-secondary text-sm mt-1 max-w-md mx-auto">
        Earmark money in your asset accounts toward specific purposes — vacations, an emergency fund, a new laptop.
      </p>
    </div>
  <% end %>
<% end %>
