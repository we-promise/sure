<div class="space-y-4">
  <div>
    <h2 class="font-medium mb-1"><%= t(".title") %></h2>
    <p class="text-secondary text-sm mb-4"><%= t(".description") %></p>
    <% if ENV["GUS_SDP_API_KEY"].present? %>
      <p class="text-sm text-secondary"><%= t(".env_configured_message") %></p>
    <% elsif Setting.gus_sdp_api_key.present? %>
      <p class="text-sm text-secondary"><%= t(".configured_in_settings_message") %></p>
    <% else %>
      <p class="text-sm text-secondary"><%= t(".free_default_message") %></p>
    <% end %>
  </div>

  <%= styled_form_with model: Setting.new,
                       url: settings_hosting_path,
                       method: :patch,
                       data: {
                         controller: "auto-submit-form",
                         "auto-submit-form-trigger-event-value": "change"
                       } do |form| %>
    <div class="flex items-center justify-between">
      <div class="space-y-1">
        <p class="text-sm"><%= t(".import_enabled_label") %></p>
        <p class="text-secondary text-sm"><%= t(".import_enabled_help") %></p>
      </div>

      <%= form.toggle :gus_inflation_import_enabled,
                      checked: Setting.gus_inflation_import_enabled_effective,
                      disabled: ENV["GUS_INFLATION_IMPORT_ENABLED"].present?,
                      data: { auto_submit_form_target: "auto" } %>
    </div>
    <% if ENV["GUS_INFLATION_IMPORT_ENABLED"].present? %>
      <p class="text-xs text-secondary mt-1"><%= t(".import_enabled_env_locked") %></p>
    <% end %>
  <% end %>

  <%= styled_form_with model: Setting.new,
                       url: settings_hosting_path,
                       method: :patch,
                       data: {
                         controller: "auto-submit-form",
                         "auto-submit-form-trigger-event-value": "blur"
                       } do |form| %>
    <% if ENV["GUS_SDP_API_KEY"].blank? %>
      <%= form.text_field :gus_sdp_api_key,
                          label: t(".label"),
                          type: "password",
                          placeholder: t(".placeholder"),
                          value: "",
                          data: { "auto-submit-form-target": "auto" } %>
    <% else %>
      <div class="text-secondary text-sm">
        <%= t(".configured_via_env") %>
      </div>
    <% end %>
  <% end %>

  <% if ENV["GUS_SDP_API_KEY"].blank? && Setting.gus_sdp_api_key.present? %>
    <%= styled_form_with model: Setting.new,
                         url: settings_hosting_path,
                         method: :patch do |form| %>
      <%= form.hidden_field :clear_gus_sdp_api_key, value: "1" %>
      <%= form.submit t(".clear_api_key"), data: { turbo_confirm: t(".clear_api_key_confirm") } %>
    <% end %>
  <% end %>

  <%= styled_form_with model: Setting.new,
                       url: import_gus_inflation_rates_settings_hosting_path,
                       method: :post do |form| %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      <%= form.number_field :gus_inflation_start_year,
                            label: t(".start_year"),
                            value: Date.current.year - 20,
                            min: 1990,
                            max: Date.current.year,
                            disabled: !Setting.gus_inflation_import_enabled_effective %>
      <%= form.number_field :gus_inflation_end_year,
                            label: t(".end_year"),
                            value: Date.current.year - 1,
                            min: 1990,
                            max: Date.current.year,
                            disabled: !Setting.gus_inflation_import_enabled_effective %>
    </div>

    <div class="mt-3">
      <%= form.submit t(".import_now"), disabled: !Setting.gus_inflation_import_enabled_effective %>
    </div>
  <% end %>

  <div class="text-sm text-secondary">
    <p>
      <strong><%= t(".last_import") %>:</strong>
      <%= Setting.gus_inflation_last_import_at.present? ? l(Setting.gus_inflation_last_import_at, format: :long) : t(".never") %>
    </p>
    <% if Setting.gus_inflation_last_import_range.present? %>
      <p><strong><%= t(".last_range") %>:</strong> <%= Setting.gus_inflation_last_import_range %></p>
    <% end %>
    <% if Setting.gus_inflation_last_import_count.present? %>
      <p><strong><%= t(".last_count") %>:</strong> <%= Setting.gus_inflation_last_import_count %></p>
    <% end %>
    <% if Setting.gus_inflation_last_import_error.present? %>
      <p class="text-destructive"><strong><%= t(".last_error") %>:</strong> <%= Setting.gus_inflation_last_import_error %></p>
    <% end %>
    <p><strong><%= t(".stored_records") %>:</strong> <%= @gus_stats[:count] %></p>
    <% if @gus_stats[:count] > 0 %>
      <p>
        <strong><%= t(".stored_range") %>:</strong>
        <%= @gus_stats[:min_year] %>-<%= @gus_stats[:max_year] %>
      </p>
    <% end %>
  </div>
</div>
