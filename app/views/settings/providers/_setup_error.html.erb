<%# locals: (error:)                                                            %>
<%# Prominent inline block for adapter-translated link-flow errors. Replaces  %>
<%# the small flash toast (which clips to 3 lines / 320px) for cases that    %>
<%# carry actionable detail like a copyable redirect URI.                    %>
<% provider_label = error["provider_key"]&.titleize.presence || error["provider_key"].to_s %>
<div class="p-4 rounded-lg bg-destructive/5 border border-destructive/20"
     role="alert">
  <div class="flex items-start gap-3">
    <%= icon("alert-circle", class: "w-5 h-5 text-destructive shrink-0 mt-0.5") %>
    <div class="flex-1 min-w-0">
      <h3 class="text-sm font-semibold text-primary mb-1">
        <%= t("settings.providers.setup_error.title", provider: provider_label) %>
      </h3>
      <p class="text-sm text-secondary"><%= error["message"] %></p>
      <% if error["redirect_uri"].present? %>
        <div class="mt-3 flex items-center gap-2 p-2 rounded bg-surface-inset border border-primary"
             data-controller="clipboard"
             data-clipboard-success-content-value="<%= t("settings.providers.setup_error.copied") %>">
          <code class="text-xs text-primary flex-1 break-all"
                data-clipboard-target="source"><%= error["redirect_uri"] %></code>
          <button type="button"
                  data-action="click->clipboard#copy"
                  data-clipboard-target="button"
                  class="shrink-0 text-xs text-secondary hover:text-primary">
            <%= t("settings.providers.setup_error.copy") %>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
