<div class="space-y-4">
  <div class="prose prose-sm text-secondary">
    <p class="text-primary font-medium"><%= t("myfund_items.panel.setup_title") %></p>
    <ol>
      <li><%= t("myfund_items.panel.step_1") %></li>
      <li><%= t("myfund_items.panel.step_2") %></li>
      <li><%= t("myfund_items.panel.step_3") %></li>
    </ol>

    <p class="text-primary font-medium"><%= t("myfund_items.panel.fields_title") %></p>
    <ul>
      <li><strong><%= t("myfund_items.panel.api_key_label") %>:</strong> <%= t("myfund_items.panel.api_key_description") %></li>
      <li><strong><%= t("myfund_items.panel.portfolio_name_label") %>:</strong> <%= t("myfund_items.panel.portfolio_name_description") %></li>
    </ul>
  </div>

  <% error_msg = local_assigns[:error_message] || @error_message %>
  <% if error_msg.present? %>
    <div class="p-2 rounded-md bg-destructive/10 text-destructive text-sm overflow-hidden">
      <p class="line-clamp-3" title="<%= error_msg %>"><%= error_msg %></p>
    </div>
  <% end %>

  <%
    myfund_item = Current.family.myfund_items.first_or_initialize(name: "myFund.pl")
    is_new_record = myfund_item.new_record?
  %>

  <%= styled_form_with model: myfund_item,
                       url: is_new_record ? myfund_items_path : myfund_item_path(myfund_item),
                       scope: :myfund_item,
                       method: is_new_record ? :post : :patch,
                       data: { turbo: true },
                       class: "space-y-3" do |form| %>
    <%= form.text_field :api_key,
                        label: t("myfund_items.panel.api_key_label"),
                        placeholder: is_new_record ? t("myfund_items.panel.api_key_placeholder") : t("myfund_items.panel.api_key_update_placeholder"),
                        type: :password %>

    <%= form.text_field :portfolio_name,
                        label: t("myfund_items.panel.portfolio_name_label"),
                        placeholder: t("myfund_items.panel.portfolio_name_placeholder"),
                        value: myfund_item.portfolio_name %>

    <div class="flex justify-end gap-2">
      <% unless is_new_record %>
        <%= link_to t("myfund_items.panel.sync_now"),
                    sync_myfund_item_path(myfund_item),
                    method: :post,
                    data: { turbo_method: :post },
                    class: "inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-medium text-primary bg-container border border-primary hover:bg-surface-hover focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 transition-colors" %>
      <% end %>

      <%= form.submit is_new_record ? t("myfund_items.panel.save") : t("myfund_items.panel.update"),
                      class: "inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-medium text-white bg-gray-900 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 transition-colors" %>
    </div>
  <% end %>

  <% items = local_assigns[:myfund_items] || @myfund_items || Current.family.myfund_items.where.not(api_key: nil) %>
  <div class="flex items-center gap-2">
    <% if items&.any? %>
      <div class="w-2 h-2 bg-success rounded-full"></div>
      <p class="text-sm text-secondary">
        <%= t("myfund_items.panel.configured") %>
        <% item = items.first %>
        <% if item.respond_to?(:last_synced_at) && item.last_synced_at.present? %>
          — <%= t("myfund_items.panel.last_synced", time: item.last_synced_at.strftime("%Y-%m-%d %H:%M")) %>
        <% end %>
      </p>
    <% else %>
      <div class="w-2 h-2 bg-gray-400 rounded-full"></div>
      <p class="text-sm text-secondary"><%= t("myfund_items.panel.not_configured") %></p>
    <% end %>
  </div>
</div>
