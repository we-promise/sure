<div class="space-y-4">
  <div class="prose prose-sm text-secondary">
    <p class="text-primary font-medium"><%= t("myfund_items.panel.setup_title") %></p>
    <ol>
      <li><%= t("myfund_items.panel.step_1") %></li>
      <li><%= t("myfund_items.panel.step_2") %></li>
      <li><%= t("myfund_items.panel.step_3") %></li>
    </ol>

    <p class="text-primary font-medium"><%= t("myfund_items.panel.fields_title") %></p>
    <ul>
      <li><strong><%= t("myfund_items.panel.api_key_label") %>:</strong> <%= t("myfund_items.panel.api_key_description") %></li>
      <li><strong><%= t("myfund_items.panel.portfolio_name_label") %>:</strong> <%= t("myfund_items.panel.portfolio_name_description") %></li>
    </ul>
  </div>

  <% error_msg = local_assigns[:error_message] || @error_message %>
  <% if error_msg.present? %>
    <div class="p-2 rounded-md bg-destructive/10 text-destructive text-sm overflow-hidden">
      <p class="line-clamp-3" title="<%= error_msg %>"><%= error_msg %></p>
    </div>
  <% end %>

  <%# List existing portfolios %>
  <% existing_items = local_assigns[:myfund_items].presence || Current.family.myfund_items.active.ordered %>
  <% if existing_items.any? %>
    <div class="space-y-3">
      <p class="text-sm font-medium text-primary"><%= t("myfund_items.panel.your_portfolios") %></p>
      <% existing_items.each do |item| %>
        <div class="flex items-center justify-between p-3 rounded-lg border border-primary bg-container">
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 bg-success rounded-full"></div>
            <div>
              <p class="text-sm font-medium text-primary"><%= item.portfolio_name %> <% if item.account %><span class="text-secondary font-normal">→ <%= item.account.name %></span><% end %></p>
              <p class="text-xs text-secondary">
                <% if item.last_synced_at.present? %>
                  <%= t("myfund_items.panel.last_synced", time: item.last_synced_at.strftime("%Y-%m-%d %H:%M")) %>
                <% else %>
                  <%= t("myfund_items.panel.never_synced") %>
                <% end %>
              </p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <%= link_to t("myfund_items.panel.sync_now"),
                        sync_myfund_item_path(item),
                        data: { turbo_method: :post },
                        class: "inline-flex items-center justify-center rounded-lg px-3 py-1.5 text-xs font-medium text-primary bg-container border border-primary hover:bg-surface-hover transition-colors" %>
            <%= link_to t("myfund_items.panel.remove"),
                        myfund_item_path(item),
                        data: { turbo_method: :delete, turbo_confirm: t("myfund_items.panel.remove_confirm") },
                        class: "inline-flex items-center justify-center rounded-lg px-3 py-1.5 text-xs font-medium text-destructive hover:bg-destructive/10 transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Form to add a new portfolio %>
  <div class="border-t border-primary pt-4">
    <p class="text-sm font-medium text-primary mb-3"><%= t("myfund_items.panel.add_portfolio") %></p>

    <%= styled_form_with model: MyfundItem.new,
                         url: myfund_items_path,
                         scope: :myfund_item,
                         method: :post,
                         data: { turbo: true },
                         class: "space-y-3" do |form| %>
      <%= form.text_field :api_key,
                          label: t("myfund_items.panel.api_key_label"),
                          placeholder: t("myfund_items.panel.api_key_placeholder"),
                          type: :password %>

      <%= form.text_field :portfolio_name,
                          label: t("myfund_items.panel.portfolio_name_label"),
                          placeholder: t("myfund_items.panel.portfolio_name_placeholder") %>

      <div class="flex justify-end">
        <%= form.submit t("myfund_items.panel.add"),
                        class: "inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-medium text-white bg-gray-900 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 transition-colors" %>
      </div>
    <% end %>
  </div>

  <% unless existing_items.any? %>
    <div class="flex items-center gap-2">
      <div class="w-2 h-2 bg-gray-400 rounded-full"></div>
      <p class="text-sm text-secondary"><%= t("myfund_items.panel.not_configured") %></p>
    </div>
  <% end %>
</div>
