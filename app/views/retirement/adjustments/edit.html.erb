    [ t("breadcrumbs.home"), root_path ],
    [ t("breadcrumbs.retirement"), retirement_path ],
    [ t("retirement.adjustments.edit_title"), nil ]
  ] %>
<% end %>

<div class="max-w-xl mx-auto space-y-4">
  <h1 class="text-primary text-xl font-semibold"><%= t("retirement.adjustments.edit_title") %></h1>
  <%= render "form", adjustment: @adjustment %>
</div>
