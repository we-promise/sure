<% content_for :page_header do %>
  <div class="space-y-4 mb-6">
    <header class="flex justify-between items-center text-primary font-medium gap-4">
      <div class="space-y-1">
        <h1 class="text-xl lg:text-3xl font-medium text-primary">
          <%= t("insights.index.title") %>
        </h1>
        <p class="text-sm lg:text-base text-secondary">
          <%= t("insights.index.subtitle") %>
        </p>
      </div>

      <%= render DS::Button.new(
            text: t("insights.index.refresh"),
            icon: "refresh-cw",
            variant: "outline",
            size: "sm",
            href: refresh_insights_path,
            method: :post,
          ) %>
    </header>

    <% if flash[:notice].present? %>
      <div class="p-3 rounded-lg bg-surface-inset text-sm text-secondary">
        <%= flash[:notice] %>
      </div>
    <% end %>
  </div>
<% end %>

<% if @insights.any? %>
  <div id="insights_list" class="space-y-3 pb-6 lg:pb-12">
    <%= render partial: "insights/insight_card", collection: @insights, as: :insight %>
  </div>
<% else %>
  <div class="bg-container rounded-xl shadow-border-xs p-10 text-center">
    <div class="inline-flex rounded-full bg-surface-inset p-3 mb-3">
      <%= icon("sparkles", size: "lg", class: "text-secondary") %>
    </div>
    <h2 class="text-base font-medium text-primary mb-1"><%= t("insights.index.empty_title") %></h2>
    <p class="text-sm text-secondary"><%= t("insights.index.empty_body") %></p>
  </div>
<% end %>
