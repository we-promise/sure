<%= turbo_stream_from Current.family, :insights %>

<div class="space-y-6 pb-6">
  <header class="flex items-start justify-between gap-4">
    <div>
      <div class="flex items-center gap-2">
        <h1 class="text-2xl font-semibold text-primary"><%= t(".title") %></h1>
        <%= render DS::Pill.new(label: t("shared.preview"), size: :md) %>
      </div>
      <p class="text-sm text-secondary mt-1"><%= t(".subtitle") %></p>
    </div>

    <%= render "insights/refresh_button", pending: false %>
  </header>

  <%= render "insights/list", insights: @insights, unread_ids: @unread_ids %>
</div>
