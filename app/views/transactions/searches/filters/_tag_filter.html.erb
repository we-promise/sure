<%# locals: (form:) %>
<div data-controller="list-filter">
  <div class="relative">
    <input type="search" autocomplete="off" placeholder="Filter tags" data-list-filter-target="input" data-action="input->list-filter#filter" class="block w-full bg-container border border-secondary rounded-md py-2 pl-10 pr-3 focus:ring-gray-500 sm:text-sm">
    <%= icon("search", class: "absolute inset-y-0 left-2 top-1/2 transform -translate-y-1/2") %>
  </div>
  <div class="my-2 flex flex-wrap gap-2" id="list" data-list-filter-target="list">
    <% Current.family.tags.alphabetically.each do |tag| %>
      <label class="filterable-item flex items-center gap-2 cursor-pointer" data-filter-name="<%= tag.name %>">
        <%= form.check_box :tags,
                           {
                             multiple: true,
                             checked: @q[:tags]&.include?(tag.name),
                             class: "checkbox checkbox--light"
                           },
                           tag.name,
                           nil %>
        <% color = tag_display_color(tag) %>
        <span class="border text-sm font-medium px-3 py-1 rounded-full inline-flex items-center gap-2"
              style="
                background-color: color-mix(in oklab, <%= color %> 10%, transparent);
                border-color: color-mix(in oklab, <%= color %> 20%, transparent);
                color: <%= color %>;">
          <span class="size-1.5 rounded-full" style="background-color: <%= color %>;"></span>
          <%= tag.name %>
        </span>
      </label>
    <% end %>
  </div>
</div>
