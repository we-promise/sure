<%= turbo_frame_tag "categorize_entry_#{entry.id}" do %>
  <%# Hidden input lives inside the frame — removed automatically when the frame is removed %>
  <input type="hidden" name="all_entry_ids[]" value="<%= entry.id %>">
  <div class="flex items-center gap-3 px-4 py-3 hover:bg-surface-hover">
    <input type="checkbox" name="entry_ids[]" value="<%= entry.id %>"
           checked class="checkbox checkbox--light shrink-0"
           data-action="change->categorize#uncheckRule" />
    <span class="flex-1 min-w-0 text-sm font-medium text-primary truncate"><%= entry.name %></span>
    <span class="text-sm text-secondary shrink-0"><%= l(entry.date, format: :short) %></span>
    <span class="text-sm font-medium shrink-0 <%= entry.amount.negative? ? "text-green-600" : "text-primary" %>">
      <%= format_money(entry.amount_money.abs) %>
    </span>

    <%# Individual assignment — removes this row on change %>
    <%= select_tag "category_id",
          options_from_collection_for_select(categories, :id, :name),
          prompt: t("transactions.categorizes.show.assign_category_prompt"),
          class: "text-xs border border-primary rounded-lg px-1.5 py-0.5 max-w-[120px] bg-container text-secondary",
          data: { entry_id: entry.id, action: "change->categorize#assignEntry" } %>
  </div>
<% end %>
