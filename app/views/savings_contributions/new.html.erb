<%= render DS::Dialog.new do |dialog| %>
  <% dialog.with_header(title: t("savings_contributions.new.title", goal_name: @savings_goal.name)) %>
  <% dialog.with_body do %>
    <%= styled_form_with model: @contribution, url: savings_goal_contributions_path(@savings_goal), class: "space-y-4" do |f| %>
      <% if @contribution.errors.any? %>
        <div class="p-3 rounded-lg border border-destructive bg-red-tint-10 text-destructive">
          <ul class="list-disc list-inside text-sm">
            <% @contribution.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= f.money_field :amount,
            label: t("savings_contributions.new.amount"),
            required: true,
            disable_currency: true,
            currency_value_override: @savings_goal.currency %>
      <%= f.date_field :contributed_at,
            label: t("savings_contributions.new.date"),
            required: true,
            max: Date.current %>
      <%= f.text_area :notes, label: t("savings_contributions.new.notes"), rows: 2 %>

      <div class="flex items-center justify-end gap-2">
        <%= f.submit t("savings_contributions.new.submit") %>
      </div>
    <% end %>
  <% end %>
<% end %>
