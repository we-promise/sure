    <%= icon("mail", size: "2xl") %>
  </div>
  <h2 class="text-lg font-semibold text-primary"><%= t(".heading") %></h2>
  <p class="text-sm text-secondary mt-1 max-w-md mx-auto"><%= t(".body") %></p>
  <div class="mt-5">
