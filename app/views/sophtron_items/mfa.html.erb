<%= turbo_frame_tag "modal" do %>
  <%= render DS::Dialog.new do |dialog| %>
    <% dialog.with_header(title: t(".title")) %>

    <% dialog.with_body do %>
      <div class="space-y-4">
        <% if @challenge[:security_questions].any? %>
          <%= form_with url: submit_mfa_sophtron_item_path(@sophtron_item), method: :post, class: "space-y-3", data: { turbo_frame: "modal" } do %>
            <%= hidden_field_tag :mfa_type, "security_answer" %>
            <%= hidden_field_tag :accountable_type, @accountable_type %>
            <%= hidden_field_tag :account_id, @account_id %>
            <%= hidden_field_tag :return_to, @return_to %>

            <% @challenge[:security_questions].each do |question| %>
              <div>
                <%= label_tag "security_answers[]", question, class: "block text-sm font-medium text-primary mb-1" %>
                <%= text_field_tag "security_answers[]", nil, autocomplete: "off", class: "form-field__input" %>
              </div>
            <% end %>

            <div class="flex justify-end">
              <%= submit_tag t(".submit"), class: "inline-flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg text-inverse bg-inverse hover:bg-inverse-hover" %>
            </div>
          <% end %>
        <% elsif @challenge[:token_methods].any? %>
          <div class="space-y-2">
            <% @challenge[:token_methods].each do |method| %>
              <%= form_with url: submit_mfa_sophtron_item_path(@sophtron_item), method: :post, data: { turbo_frame: "modal" } do %>
                <%= hidden_field_tag :mfa_type, "token_choice" %>
                <%= hidden_field_tag :token_choice, method %>
                <%= hidden_field_tag :accountable_type, @accountable_type %>
                <%= hidden_field_tag :account_id, @account_id %>
                <%= hidden_field_tag :return_to, @return_to %>
                <%= submit_tag method, class: "w-full text-left p-3 border border-primary rounded-lg hover:bg-subtle text-sm text-primary" %>
              <% end %>
            <% end %>
          </div>
        <% elsif @challenge[:token_sent] %>
          <%= form_with url: submit_mfa_sophtron_item_path(@sophtron_item), method: :post, class: "space-y-3", data: { turbo_frame: "modal" } do %>
            <%= hidden_field_tag :mfa_type, "token_input" %>
            <%= hidden_field_tag :accountable_type, @accountable_type %>
            <%= hidden_field_tag :account_id, @account_id %>
            <%= hidden_field_tag :return_to, @return_to %>
            <div>
              <%= label_tag :token_input, t(".token"), class: "block text-sm font-medium text-primary mb-1" %>
              <%= text_field_tag :token_input, nil, autocomplete: "one-time-code", class: "form-field__input" %>
            </div>
            <div class="flex justify-end">
              <%= submit_tag t(".submit"), class: "inline-flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg text-inverse bg-inverse hover:bg-inverse-hover" %>
            </div>
          <% end %>
        <% elsif @challenge[:token_read].present? %>
          <div class="space-y-3">
            <p class="text-sm text-primary"><%= @challenge[:token_read] %></p>
            <%= form_with url: submit_mfa_sophtron_item_path(@sophtron_item), method: :post, data: { turbo_frame: "modal" } do %>
              <%= hidden_field_tag :mfa_type, "verify_phone" %>
              <%= hidden_field_tag :accountable_type, @accountable_type %>
              <%= hidden_field_tag :account_id, @account_id %>
              <%= hidden_field_tag :return_to, @return_to %>
              <%= submit_tag t(".phone_confirmed"), class: "inline-flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg text-inverse bg-inverse hover:bg-inverse-hover" %>
            <% end %>
          </div>
        <% elsif @challenge[:captcha_image].present? %>
          <%= form_with url: submit_mfa_sophtron_item_path(@sophtron_item), method: :post, class: "space-y-3", data: { turbo_frame: "modal" } do %>
            <%= hidden_field_tag :mfa_type, "captcha" %>
            <%= hidden_field_tag :accountable_type, @accountable_type %>
            <%= hidden_field_tag :account_id, @account_id %>
            <%= hidden_field_tag :return_to, @return_to %>
            <%= image_tag "data:image/png;base64,#{@challenge[:captcha_image]}", alt: t(".captcha_alt"), class: "max-w-full" %>
            <div>
              <%= label_tag :captcha_input, t(".captcha"), class: "block text-sm font-medium text-primary mb-1" %>
              <%= text_field_tag :captcha_input, nil, autocomplete: "off", class: "form-field__input" %>
            </div>
            <div class="flex justify-end">
              <%= submit_tag t(".submit"), class: "inline-flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg text-inverse bg-inverse hover:bg-inverse-hover" %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
