<%= content_for :header_nav do %>
  <%= render "imports/nav", import: @import %>
<% end %>

<%= content_for :previous_path, import_upload_path(@import) %>

<div class="space-y-6 mx-auto max-w-3xl mb-6">
  <div class="text-center space-y-2 max-w-xl mx-auto">
    <h1 class="text-3xl text-primary font-medium"><%= t(".title") %></h1>
    <p class="text-secondary text-sm"><%= t(".description") %></p>
  </div>

  <% if @detected_sheets.empty? %>
    <div class="flex gap-3 items-start rounded-xl border border-warning bg-warning/5 px-4 py-3">
      <%= icon("triangle-alert", size: "md", class: "text-warning shrink-0 mt-0.5") %>
      <div class="text-sm text-primary space-y-1">
        <p class="font-medium"><%= t(".none_title") %></p>
        <p class="text-secondary"><%= t(".none_description") %></p>
      </div>
    </div>

    <%= render DS::Button.new(text: t(".back_to_imports"), href: imports_path, variant: :secondary, full_width: true) %>
  <% else %>
    <%= form_with url: import_sheet_selection_path(@import), method: :put, class: "space-y-4" do |form| %>
      <div class="bg-container-inset rounded-xl p-1 space-y-1">
        <% @detected_sheets.each_with_index do |sheet, index| %>
          <% suggested = @import.suggested_account_for(sheet) %>
          <% field = "import[sheets][#{index}]" %>

          <div class="bg-container shadow-border-xs rounded-lg p-4 space-y-3">
            <input type="hidden" name="<%= field %>[sheet_name]" value="<%= sheet.sheet_name %>">

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                name="<%= field %>[selected]"
                value="1"
                id="sheet_<%= index %>"
                <%= "checked" if suggested.present? || @import.detected_sheets.size <= 1 || sheet.type == :cpt %>
                class="mt-1 rounded border-primary">

              <label for="sheet_<%= index %>" class="flex-1 cursor-pointer">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-medium text-primary"><%= sheet.account_name %></span>
                  <%= render DS::Pill.new(label: sheet.type.to_s.upcase, tone: (sheet.type == :cpt ? :info : :warning), marker: false, show_dot: false) %>
                  <% if suggested.present? %>
                    <%= render DS::Pill.new(label: t(".known_account"), tone: :success, marker: false, show_dot: false) %>
                  <% end %>
                </div>
                <div class="text-xs text-secondary mt-0.5">
                  <%= t(".account_number") %>: <span class="font-mono"><%= sheet.account_number %></span>
                  &middot; <%= t(".transactions_count", count: sheet.row_count || 0) %>
                  &middot; <%= sheet.currency %>
                </div>
              </label>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-2 pl-7">
              <select
                name="<%= field %>[account_id]"
                class="w-full rounded-lg border border-secondary bg-container px-3 py-2 text-sm text-primary">
                <option value="new" <%= "selected" if suggested.blank? %>><%= t(".create_new_account") %></option>
                <% @accounts.each do |account| %>
                  <option value="<%= account.id %>" <%= "selected" if suggested&.id == account.id %>>
                    <%= account.name %>
                  </option>
                <% end %>
              </select>

              <input
                type="text"
                name="<%= field %>[account_name]"
                value="<%= sheet.account_name %>"
                placeholder="<%= t(".new_account_name_placeholder") %>"
                class="w-full rounded-lg border border-secondary bg-container px-3 py-2 text-sm text-primary">
            </div>

            <% if sheet.sample.any? %>
              <div class="pl-7 text-xs text-secondary space-y-0.5">
                <% sheet.sample.first(2).each do |txn| %>
                  <div class="flex justify-between gap-2">
                    <span class="truncate"><%= txn[:date] %> &middot; <%= txn[:name] %></span>
                    <span class="font-mono shrink-0"><%= txn[:amount] %> <%= txn[:currency] %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%= render DS::Button.new(text: t(".import_selected"), type: :submit, full_width: true) %>
    <% end %>
  <% end %>
</div>
