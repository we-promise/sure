<%= turbo_frame_tag "modal" do %>
  <%= render DS::Dialog.new do |dialog| %>
    <% dialog.with_header(title: t(".title")) %>

    <% dialog.with_body do %>
      <% if @gocardless_accounts.blank? %>
        <div class="p-4 text-sm text-secondary">
          <p class="mb-2"><%= t(".no_accounts") %></p>
          <ul class="list-disc list-inside space-y-1">
            <li><%= t(".no_accounts_hint1_html").html_safe %></li>
            <li><%= t(".no_accounts_hint2") %></li>
          </ul>
        </div>
      <% else %>
        <%= form_with url: link_existing_account_gocardless_items_path,
                      method: :post,
                      class: "space-y-4" do %>
          <%= hidden_field_tag :account_id, @account_id %>
          <div class="space-y-2 max-h-64 overflow-auto">
            <% @gocardless_accounts.each do |gc_account| %>
              <label class="flex items-center gap-3 p-2 rounded border border-surface-inset/50 hover:border-primary cursor-pointer">
                <%= radio_button_tag :gocardless_account_id, gc_account.id, false, required: true %>
                <div class="flex flex-col">
                  <span class="text-sm text-primary font-medium">
                    <%= gc_account.name.presence || gc_account.account_id %>
                  </span>
                  <span class="text-xs text-secondary">
                    <%= gc_account.currency %> ·
                    <%= t(".balance_label") %>: <%= number_to_currency((gc_account.current_balance || 0), unit: gc_account.currency) %>
                  </span>
                </div>
              </label>
            <% end %>
          </div>

          <div class="flex items-center justify-end gap-2">
            <%= render DS::Button.new(text: "Link", variant: :primary, icon: "link-2", type: :submit) %>
            <%= render DS::Link.new(text: "Cancel", variant: :secondary, href: accounts_path, data: { turbo_frame: "_top" }) %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>