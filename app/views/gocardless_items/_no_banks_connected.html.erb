<details open class="group bg-container p-4 shadow-border-xs rounded-xl">
  <summary class="flex items-center justify-between gap-2 focus-visible:outline-hidden">
    <div class="flex items-center gap-2">
      <%= icon "chevron-right", class: "group-open:transform group-open:rotate-90" %>

      <div class="flex items-center justify-center h-8 w-8 bg-success/10 rounded-full">
        <p class="text-success text-xs font-medium">G</p>
      </div>

      <div class="pl-1 text-sm">
        <p class="font-medium text-primary">GoCardless</p>
        <p class="text-xs text-secondary">GoCardless</p>
        <p class="text-xs text-secondary">No banks connected</p>
      </div>
    </div>
  </summary>

  <div class="mt-4 p-4 flex flex-col gap-3 items-center justify-center">
    <p class="text-primary font-medium text-sm">No banks connected</p>
    <p class="text-secondary text-sm">Connect your UK bank account to start syncing transactions automatically.</p>
    <%= render DS::Link.new(
      text: "Connect a bank",
      icon: "building-2",
      variant: "primary",
      href: new_item_gocardless_items_path
    ) %>
  </div>
</details>
