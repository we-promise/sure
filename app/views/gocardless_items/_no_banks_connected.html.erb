<details open class="group bg-container p-4 shadow-border-xs rounded-xl">
  <summary class="flex items-center justify-between gap-2 rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary">
    <div class="flex items-center gap-2">
      <%= icon "chevron-right", class: "group-open:transform group-open:rotate-90" %>

      <div class="flex items-center justify-center h-8 w-8 bg-success/10 rounded-full">
        <p class="text-success text-xs font-medium">G</p>
      </div>

      <div class="pl-1 text-sm">
        <p class="font-medium text-primary"><%= t(".title") %></p>
        <p class="text-xs text-secondary"><%= t(".no_banks_connected") %></p>
      </div>
    </div>
  </summary>

  <div class="mt-4 p-4 flex flex-col gap-3 items-center justify-center">
    <p class="text-primary font-medium text-sm"><%= t(".no_banks_connected") %></p>
    <p class="text-secondary text-sm"><%= t(".hint") %></p>
    <%= render DS::Link.new(
      text: t(".connect_bank"),
      icon: "building-2",
      variant: "primary",
      href: new_item_gocardless_items_path
    ) %>
  </div>
</details>
