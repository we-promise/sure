<%= turbo_frame_tag "modal" do %>
  <%= render DS::Dialog.new do |dialog| %>
    <% dialog.with_header(title: t(".title")) %>

    <% dialog.with_body do %>
      <% if Provider::GocardlessAdapter.configured? %>
        <% items = @gocardless_items || Current.family.gocardless_items.active.ordered.includes(:gocardless_accounts) %>
        <% if items.any? %>
          <div class="space-y-3">
            <% items.each do |item| %>
              <div class="flex items-center justify-between p-3 rounded-lg bg-container border border-primary">
                <div class="flex items-center gap-3">
                  <% if item.requires_update? %>
                    <div class="w-2 h-2 bg-warning rounded-full"></div>
                    <div>
                      <p class="text-sm font-medium text-primary"><%= item.institution_name %></p>
                      <p class="text-xs text-destructive"><%= t(".reauthorisation_required") %></p>
                    </div>
                  <% else %>
                    <div class="w-2 h-2 bg-success rounded-full"></div>
                    <div>
                      <p class="text-sm font-medium text-primary"><%= item.institution_name %></p>
                      <p class="text-xs text-secondary">
                        <%= t("settings.providers.gocardless_panel.accounts_connected", count: item.gocardless_accounts.size) %>
                      </p>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <div class="border-t border-primary pt-3">
              <p class="text-sm font-medium text-primary mb-2"><%= t(".add_another_bank") %></p>
              <div data-controller="gocardless-bank-search" class="space-y-2">
                <%= select_tag :country,
                      options_for_select(@countries.map { |code, name| [name, code] }, "gb"),
                      class: "w-full appearance-none bg-container border border-primary rounded-lg px-3 py-2 text-sm text-primary focus:outline-none focus:ring-1 focus:ring-primary",
                      data: { action: "change->gocardless-bank-search#updateCountry" } %>
                <input type="text"
                       placeholder="<%= t(".search_placeholder") %>"
                       class="w-full px-3 py-2 text-sm border border-primary rounded-lg bg-transparent text-primary placeholder:text-secondary focus:outline-none focus:ring-1 focus:ring-primary"
                       autocomplete="off"
                       data-action="input->gocardless-bank-search#search" />
                <div data-gocardless-bank-search-target="results" class="space-y-1"></div>
              </div>
            </div>
          </div>
        <% else %>
          <%# No banks connected yet — show search directly %>
          <div data-controller="gocardless-bank-search" class="space-y-3">
            <p class="text-sm text-secondary">
              <%= t(".search_hint") %>
            </p>
            <%= select_tag :country,
                  options_for_select(@countries.map { |code, name| [name, code] }, "gb"),
                  class: "w-full appearance-none bg-container border border-primary rounded-lg px-3 py-2 text-sm text-primary focus:outline-none focus:ring-1 focus:ring-primary",
                  data: { action: "change->gocardless-bank-search#updateCountry" } %>
            <input type="text"
                   placeholder="<%= t(".search_placeholder") %>"
                   class="w-full px-3 py-2 text-sm border border-primary rounded-lg bg-transparent text-primary placeholder:text-secondary focus:outline-none focus:ring-1 focus:ring-primary"
                   autocomplete="off"
                   data-action="input->gocardless-bank-search#search" />
            <div data-gocardless-bank-search-target="results" class="space-y-1"></div>
          </div>
        <% end %>
      <% else %>
        <%# Not configured %>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <%= icon("alert-circle", class: "text-warning w-5 h-5 shrink-0 mt-0.5") %>
            <div class="text-sm text-secondary">
              <p class="font-medium text-primary mb-2"><%= t(".not_configured_title") %></p>
              <p><%= t(".not_configured_hint") %></p>
            </div>
          </div>

          <div class="bg-surface rounded-lg p-4 space-y-2 text-sm">
            <p class="font-medium text-primary"><%= t(".setup_steps_title") %></p>
            <ol class="list-decimal list-inside space-y-1 text-secondary">
              <li><%= t(".setup_step1_html").html_safe %></li>
              <li><%= t(".setup_step2_html").html_safe %></li>
              <li><%= t(".setup_step3") %></li>
              <li><%= t(".setup_step4") %></li>
              <li><%= t(".setup_step5") %></li>
            </ol>
          </div>

          <%= link_to settings_providers_path,
                      class: "w-full inline-flex items-center justify-center rounded-lg font-medium px-3 py-2 text-sm text-inverse bg-inverse hover:bg-inverse-hover",
                      data: { turbo: false } do %>
            <%= t(".go_to_settings") %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>