<%# locals: (gocardless_item:) %>

<%= tag.div id: dom_id(gocardless_item) do %>
  <details open class="group bg-container p-4 shadow-border-xs rounded-xl">
    <summary class="flex items-center justify-between gap-2 focus-visible:outline-hidden">
      <div class="flex items-center gap-2">
        <%= icon "chevron-right", class: "group-open:transform group-open:rotate-90" %>

        <div class="flex items-center justify-center h-8 w-8 bg-success/10 rounded-full">
          <div class="flex items-center justify-center">
            <%= tag.p gocardless_item.institution_name&.first&.upcase, class: "text-success text-xs font-medium" %>
          </div>
        </div>

        <div class="pl-1 text-sm">
          <div class="flex items-center gap-2">
            <%= tag.p gocardless_item.institution_name, class: "font-medium text-primary" %>
            <% if gocardless_item.scheduled_for_deletion? %>
              <p class="text-destructive text-sm animate-pulse"><%= t(".deletion_in_progress") %></p>
            <% end %>
          </div>
          <p class="text-xs text-secondary"><%= t(".provider_label") %></p>
          <% if gocardless_item.requires_update? || gocardless_item.agreement_expired? %>
            <div class="text-destructive flex items-center gap-1">
              <%= icon "alert-triangle", size: "sm", color: "destructive" %>
              <%= tag.span t(".auth_expired") %>
            </div>
          <% elsif gocardless_item.agreement_expiring_soon? %>
            <div class="text-warning flex items-center gap-1">
              <%= icon "alert-triangle", size: "sm", color: "warning" %>
              <%= tag.span t(".auth_expiring",
                    date: gocardless_item.agreement_expires_at.strftime("%d %b %Y"),
                    days: pluralize((gocardless_item.agreement_expires_at.to_date - Date.current).to_i, "day")) %>
            </div>
          <% else %>
            <% if gocardless_item.last_synced_at %>
              <p class="text-secondary text-xs">
                <%= t(".last_synced", time: time_ago_in_words(gocardless_item.last_synced_at)) %>
                &middot;
                <% freq_label = GocardlessItem::SYNC_FREQUENCY_OPTIONS.find { |_, v| v == gocardless_item.sync_frequency }&.first %>
                <%= freq_label %>
                <% if gocardless_item.agreement_expires_at %>
                  &middot; <%= t(".auth_expires_on", date: gocardless_item.agreement_expires_at.strftime("%d %b %Y")) %>
                <% end %>
              </p>
            <% elsif gocardless_item.accounts.any? %>
              <div class="flex items-center gap-1 text-warning">
                <%= icon "clock", size: "sm", class: "text-warning" %>
                <span class="text-xs"><%= t(".first_sync_pending") %></span>
              </div>
            <% else %>
              <p class="text-secondary text-xs"><%= t(".never_synced") %></p>
            <% end %>
          <% end %>
        </div>
      </div>

      <% if Current.user&.admin? %>
        <div class="flex items-center gap-2">
          <% if !gocardless_item.scheduled_for_deletion? && (gocardless_item.requires_update? || gocardless_item.agreement_expired?) %>
            <%= button_to reauthorize_gocardless_item_path(gocardless_item),
                          method: :post,
                          class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-xs font-medium text-destructive border border-destructive hover:bg-destructive/10 transition-colors" do %>
              <%= icon "refresh-cw", size: "xs" %>
              <%= t(".reauthorize") %>
            <% end %>
          <% elsif !gocardless_item.scheduled_for_deletion? && gocardless_item.agreement_expiring_soon? %>
            <%= button_to reauthorize_gocardless_item_path(gocardless_item),
                          method: :post,
                          class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-xs font-medium text-warning border border-warning hover:bg-warning/10 transition-colors" do %>
              <%= icon "refresh-cw", size: "xs" %>
              <%= t(".renew") %>
            <% end %>
            <%= icon(
              "refresh-cw",
              as_button: true,
              href: sync_gocardless_item_path(gocardless_item)
            ) %>
          <% elsif !gocardless_item.scheduled_for_deletion? %>
            <%= icon(
              "refresh-cw",
              as_button: true,
              href: sync_gocardless_item_path(gocardless_item)
            ) %>
          <% end %>
          <%= render DS::Menu.new do |menu| %>
            <% menu.with_item(
              variant: "button",
              text: t(".disconnect"),
              icon: "trash-2",
              href: gocardless_item_path(gocardless_item),
              method: :delete,
              confirm: CustomConfirm.for_resource_deletion(gocardless_item.institution_name, high_severity: true)
            ) %>
          <% end %>
        </div>
      <% end %>
    </summary>

    <% unless gocardless_item.scheduled_for_deletion? %>
      <div class="space-y-4 mt-4">
        <% if gocardless_item.accounts.any? %>
          <%= render "accounts/index/account_groups", accounts: gocardless_item.accounts %>
        <% end %>

        <%# Sync summary — mirrors the pattern used by LunchFlow, Plaid, SimpleFIN etc. %>
        <% stats = gocardless_item.syncs.ordered.first&.sync_stats || {} %>
        <%= render ProviderSyncSummary.new(
          stats: stats,
          provider_item: gocardless_item,
          institutions_count: 1
        ) %>

        <% unlinked_count = gocardless_item.unlinked_accounts_count %>
        <% linked_count   = gocardless_item.linked_accounts_count %>
        <% total_count    = gocardless_item.total_accounts_count %>

        <% if unlinked_count > 0 %>
          <div class="p-4 flex flex-col gap-3 items-center justify-center">
            <p class="text-primary font-medium text-sm"><%= t(".accounts_need_setup") %></p>
            <p class="text-secondary text-sm">
              <%= t(".accounts_setup_progress", linked: linked_count, total: total_count, count: unlinked_count) %>
            </p>
            <%= render DS::Link.new(
              text: t(".set_up_accounts"),
              icon: "settings",
              variant: "primary",
              href: setup_accounts_gocardless_item_path(gocardless_item)
            ) %>
          </div>
        <% elsif gocardless_item.accounts.empty? && total_count == 0 %>
          <div class="p-4 flex flex-col gap-3 items-center justify-center">
            <p class="text-primary font-medium text-sm"><%= t(".no_accounts_found") %></p>
            <p class="text-secondary text-sm"><%= t(".no_accounts_imported") %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </details>
<% end %>
