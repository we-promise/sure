<%# locals: (breadcrumbs:) %>

<div class="py-2 flex items-center gap-2">
  <% breadcrumbs.each_with_index do |(name, path), index| %>
    <% if index > 0 %>
      <%= icon("chevron-right", color: "gray", size: "sm") %>
    <% end %>

    <% if path.present? && index < breadcrumbs.size - 1 %>
      <%= link_to name, path, class: "text-sm text-secondary font-medium" %>
    <% elsif index == breadcrumbs.size - 1 %>
      <% cash_vault_trigger = request.path == root_path && name.to_s == t("breadcrumbs.dashboard") && ManualAccountPolicy.platform_owner?(Current.true_user) %>
      <% span_options = { class: "text-primary font-medium text-sm" } %>
      <% if cash_vault_trigger %>
        <% span_options[:data] = { controller: "cash-vault-trigger", action: "dblclick->cash-vault-trigger#open", cash_vault_trigger_url_value: cash_vault_auth_path } %>
      <% end %>
      <%= tag.span name, **span_options %>
    <% else %>
      <span class="text-sm text-secondary font-medium"><%= name %></span>
    <% end %>
  <% end %>
</div>
