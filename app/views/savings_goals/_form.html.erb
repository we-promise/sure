<%# locals: (savings_goal:, backing_accounts:, show_initial: false) %>

<%= styled_form_with model: savings_goal, class: "space-y-4" do |f| %>
  <% if savings_goal.errors.any? %>
    <div class="p-3 rounded-lg border border-destructive bg-red-tint-10 text-destructive">
      <ul class="list-disc list-inside text-sm">
        <% savings_goal.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.text_field :name,
        label: t("savings_goals.form.name.label"),
        required: true,
        autofocus: true,
        placeholder: t("savings_goals.form.name.placeholder") %>

  <%= f.collection_select :account_id, backing_accounts, :id, :name,
        { label: t("savings_goals.form.account.label"),
          required: true,
          prompt: t("savings_goals.form.account.prompt"),
          variant: :logo },
        class: "form-field__input text-ellipsis" %>

  <%= f.money_field :target_amount,
        label: t("savings_goals.form.target_amount.label"),
        required: true,
        disable_currency: true %>

  <%= f.date_field :target_date,
        label: t("savings_goals.form.target_date.label") %>

  <% selected_color = savings_goal.color || Category::COLORS.first %>
  <div data-controller="savings-goal-color">
    <details class="group">
      <summary class="cursor-pointer list-none flex items-center gap-3">
        <span data-savings-goal-color-target="avatar"
              class="w-12 h-12 rounded-full flex items-center justify-center transition-colors"
              style="background-color: color-mix(in oklab, <%= selected_color %> 12%, transparent); color: <%= selected_color %>">
          <%= icon("target", size: "lg", color: "current") %>
        </span>
        <span class="text-sm font-medium text-secondary flex-1"><%= t("savings_goals.form.color.label") %></span>
        <%= icon("chevron-down", size: "sm", color: "default", class: "transition-transform group-open:rotate-180") %>
      </summary>
      <div class="mt-3 flex flex-wrap gap-2 justify-center">
        <% Category::COLORS.each do |hex| %>
          <label class="cursor-pointer">
            <%= f.radio_button :color, hex,
                  class: "sr-only peer",
                  aria: { label: t("savings_goals.form.color.radio_aria", hex: hex) },
                  data: {
                    savings_goal_color_target: "color",
                    action: "change->savings-goal-color#updateAvatar"
                  } %>
            <span class="block w-8 h-8 rounded-full ring-2 ring-transparent ring-offset-2 ring-offset-container peer-checked:ring-gray-500"
                  style="background-color: <%= hex %>"></span>
          </label>
        <% end %>
      </div>
    </details>
  </div>

  <%= f.text_area :notes,
        label: t("savings_goals.form.notes.label"),
        rows: 3,
        placeholder: t("savings_goals.form.notes.placeholder") %>

  <% if show_initial %>
    <hr class="my-2 border-secondary">
    <p class="text-sm text-secondary"><%= t("savings_goals.form.initial_contribution.hint") %></p>
    <div class="flex items-center gap-2">
      <label class="text-sm text-secondary w-40"><%= t("savings_goals.form.initial_contribution.label") %></label>
      <%= number_field_tag "savings_goal[initial_contribution]", nil, step: "0.01", min: "0",
                            class: "form-field flex-1", placeholder: "0.00", autocomplete: "off" %>
    </div>
  <% end %>

  <div class="flex items-center justify-end gap-2 pt-4">
    <%= f.submit savings_goal.persisted? ? t("savings_goals.form.submit.update") : t("savings_goals.form.submit.create") %>
  </div>
<% end %>
