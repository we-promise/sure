<div class="p-6">
  <h1 class="text-2xl font-medium"><%= controller_name.titleize %> / <%= action_name %></h1>
  <p class="text-secondary">Savings goals — placeholder view; real UI in step 6.</p>
  <% if @savings_goal %><pre><%= @savings_goal.attributes.except("notes").inspect %></pre><% end %>
  <% if @savings_goals %>
    <ul>
      <% @savings_goals.each do |g| %>
        <li><%= link_to g.name, savings_goal_path(g) %> — <%= number_to_currency(g.current_balance, unit: "") %> / <%= number_to_currency(g.target_amount, unit: "") %> (<%= g.state %>)</li>
      <% end %>
    </ul>
  <% end %>
</div>
