<% state_pill_classes = case @savings_goal.state
   when "active"    then "bg-success/10 text-success"
   when "paused"    then "bg-warning/10 text-warning"
   when "completed" then "bg-success/20 text-success"
   when "archived"  then "bg-container-inset text-secondary"
   else                  "bg-container-inset text-secondary"
   end %>

<% balance_money = @savings_goal.current_balance_money %>
<% target_money = Money.new(@savings_goal.target_amount, @savings_goal.currency) %>

<div class="max-w-3xl mx-auto py-6 space-y-6">
  <%# Header card: ring + identity + actions %>
  <div class="bg-container rounded-xl shadow-border-xs p-6 lg:p-8">
    <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
      <%= render Savings::ProgressRingComponent.new(
        percent: @savings_goal.progress_percent,
        size: 180,
        stroke: 12,
        color: @savings_goal.color,
        label_lines: [
          format_money(balance_money),
          "of #{format_money(target_money)}",
          "#{@savings_goal.progress_percent}%"
        ]
      ) %>

      <div class="grow text-center md:text-left space-y-2">
        <h1 class="text-2xl text-primary font-medium"><%= @savings_goal.name %></h1>
        <div class="flex items-center gap-2 flex-wrap justify-center md:justify-start">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium <%= state_pill_classes %>">
            <%= @savings_goal.state.titleize %>
          </span>
          <span class="text-secondary text-sm"><%= @savings_goal.account.name %></span>
          <% if @savings_goal.target_date %>
            <span class="text-secondary text-sm">· target <%= @savings_goal.target_date.strftime("%b %Y") %></span>
          <% end %>
        </div>
        <% if @savings_goal.monthly_target_amount %>
          <p class="text-secondary text-sm">
            Monthly target: <span class="text-primary font-medium"><%= format_money Money.new(@savings_goal.monthly_target_amount, @savings_goal.currency) %></span>
          </p>
        <% end %>
      </div>

      <div class="flex items-center gap-1 shrink-0">
        <%= render DS::Link.new(variant: "icon", icon: "pencil",
              href: edit_savings_goal_path(@savings_goal),
              frame: :modal,
              title: "Edit", "aria-label": "Edit goal") %>

        <%= render DS::Menu.new do |menu| %>
          <% if @savings_goal.may_pause? %>
            <% menu.with_item(variant: "button", text: "Pause",
                  icon: "pause",
                  href: pause_savings_goal_path(@savings_goal),
                  method: :patch) %>
          <% end %>
          <% if @savings_goal.may_resume? %>
            <% menu.with_item(variant: "button", text: "Resume",
                  icon: "play",
                  href: resume_savings_goal_path(@savings_goal),
                  method: :patch) %>
          <% end %>
          <% if @savings_goal.may_complete? %>
            <% menu.with_item(variant: "button", text: "Mark complete",
                  icon: "check",
                  href: complete_savings_goal_path(@savings_goal),
                  method: :patch) %>
          <% end %>
          <% if @savings_goal.may_archive? %>
            <% menu.with_item(variant: "button", text: "Archive",
                  icon: "archive",
                  href: archive_savings_goal_path(@savings_goal),
                  method: :patch) %>
          <% end %>
          <% if @savings_goal.may_unarchive? %>
            <% menu.with_item(variant: "button", text: "Restore to active",
                  icon: "rotate-ccw",
                  href: unarchive_savings_goal_path(@savings_goal),
                  method: :patch) %>
          <% end %>

          <% menu.with_item(variant: "button", text: "Delete",
                icon: "trash-2",
                href: savings_goal_path(@savings_goal),
                method: :delete,
                destructive: true,
                confirm: CustomConfirm.for_resource_deletion(@savings_goal.name)) %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @savings_goal.notes.present? %>
    <div class="bg-container rounded-xl shadow-border-xs p-6">
      <p class="text-secondary text-xs uppercase tracking-wide mb-2">Notes</p>
      <p class="text-primary whitespace-pre-line"><%= @savings_goal.notes %></p>
    </div>
  <% end %>

  <div class="bg-container rounded-xl shadow-border-xs p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-primary font-medium">Contributions</h2>
      <%= render DS::Link.new(text: "Add contribution", icon: "plus", variant: "primary",
            href: new_savings_goal_contribution_path(@savings_goal),
            frame: :modal) %>
    </div>

    <% contributions = @savings_goal.savings_contributions.recent_first %>
    <% if contributions.any? %>
      <ul class="divide-y divide-alpha-black-200 theme-dark:divide-alpha-white-200">
        <% contributions.each do |c| %>
          <li class="flex items-center justify-between py-3">
            <div>
              <p class="text-primary text-sm">
                <%= format_money Money.new(c.amount, c.currency) %>
                <span class="text-secondary text-xs ml-2 px-2 py-0.5 rounded-full bg-container-inset"><%= c.source.titleize %></span>
              </p>
              <p class="text-secondary text-xs"><%= c.contributed_at.strftime("%b %-d, %Y") %><% if c.notes.present? %> · <%= c.notes %><% end %></p>
            </div>
            <%= render DS::Button.new(
                  variant: "icon",
                  icon: "trash-2",
                  size: "sm",
                  href: savings_goal_contribution_path(@savings_goal, c),
                  method: :delete,
                  confirm: CustomConfirm.for_resource_deletion("this contribution"),
                  class: "[&_svg]:!text-destructive",
                  title: "Remove contribution",
                  "aria-label": "Remove contribution"
                ) %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-secondary text-sm">No contributions yet. Add one to start tracking progress.</p>
    <% end %>
  </div>
</div>
