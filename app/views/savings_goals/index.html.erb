<div class="flex items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-primary text-2xl font-medium"><%= t(".title") %></h1>
    <p class="text-secondary text-sm"><%= t(".description") %></p>
  </div>
  <%= render DS::Link.new(
    text: t(".new_goal"),
    icon: "plus",
    variant: "primary",
    href: new_savings_goal_path,
    frame: :modal
  ) %>
</div>

<nav class="flex bg-surface-inset p-1 rounded-lg mb-4 gap-1">
  <% %w[all active paused completed archived].each do |state| %>
    <% active = (@state == state) %>
    <%= link_to t(".tabs.#{state}"),
                savings_goals_path(state: state),
                class: class_names(
                  "flex-1 inline-flex justify-center items-center text-sm font-medium px-2 py-1 rounded-md transition-colors duration-200",
                  active ? "bg-white theme-dark:bg-gray-700 text-primary shadow-sm" : "text-secondary hover:bg-surface-inset-hover"
                ) %>
  <% end %>
</nav>

<% if @savings_goals.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @savings_goals.each do |goal| %>
      <%= render Savings::GoalCardComponent.new(goal: goal) %>
    <% end %>
  </div>
<% else %>
  <div class="bg-container rounded-xl shadow-border-xs p-12 text-center">
    <p class="text-primary font-medium">
      <% if @state == "all" %>
        <%= t(".empty.all") %>
      <% else %>
        <%= t(".empty.filtered", state: t(".tabs.#{@state}").downcase) %>
      <% end %>
    </p>
    <p class="text-secondary text-sm mt-1"><%= t(".empty.cta") %></p>
    <div class="mt-4">
      <%= render DS::Link.new(text: t(".new_goal"), icon: "plus", variant: "primary", href: new_savings_goal_path, frame: :modal) %>
    </div>
  </div>
<% end %>
