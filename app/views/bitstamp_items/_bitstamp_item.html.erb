<%# locals: (bitstamp_item:, unlinked_count: bitstamp_item.unlinked_accounts_count) %>

<%= tag.div id: dom_id(bitstamp_item) do %>
  <%= render DS::Disclosure.new(variant: :card, open: true) do |disclosure| %>
    <% disclosure.with_summary_content do %>
      <div class="flex items-center gap-2">
        <%= icon "chevron-right", class: "group-open:rotate-90 motion-safe:transition-transform motion-safe:duration-150" %>

        <div class="flex items-center justify-center h-8 w-8 rounded-full bg-surface-inset">
          <%= icon "coins", size: "sm", class: "text-primary" %>
        </div>

        <div class="pl-1 text-sm flex-1">
          <div class="flex items-center gap-2">
            <%= tag.p bitstamp_item.institution_display_name, class: "font-medium text-primary" %>
            <% if bitstamp_item.scheduled_for_deletion? %>
              <p class="text-destructive text-sm animate-pulse"><%= t(".deletion_in_progress") %></p>
            <% end %>
          </div>
          <p class="text-xs text-secondary"><%= t(".provider_name") %></p>

          <% if bitstamp_item.syncing? %>
            <div class="text-secondary flex items-center gap-1">
              <%= icon "loader", size: "sm", class: "animate-spin" %>
              <%= tag.span t(".syncing") %>
            </div>
          <% elsif bitstamp_item.requires_update? %>
            <div class="text-warning flex items-center gap-1">
              <%= icon "alert-triangle", size: "sm", color: "warning" %>
              <%= tag.span t(".reconnect") %>
            </div>
          <% else %>
            <p class="text-secondary">
              <% if bitstamp_item.last_synced_at %>
                <% if bitstamp_item.sync_status_summary %>
                  <%= t(".status_with_summary", timestamp: time_ago_in_words(bitstamp_item.last_synced_at), summary: bitstamp_item.sync_status_summary) %>
                <% else %>
                  <%= t(".status", timestamp: time_ago_in_words(bitstamp_item.last_synced_at)) %>
                <% end %>
              <% else %>
                <%= t(".status_never") %>
              <% end %>
            </p>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if Current.user&.admin? %>
      <div class="flex items-center justify-end gap-2 mt-2">
        <%= icon(
          "refresh-cw",
          as_button: true,
          href: sync_bitstamp_item_path(bitstamp_item),
          disabled: bitstamp_item.syncing?
        ) %>

        <%= render DS::Menu.new do |menu| %>
          <% if unlinked_count.to_i > 0 %>
            <% menu.with_item(
              variant: "link",
              text: t(".import_accounts_menu"),
              icon: "plus",
              href: setup_accounts_bitstamp_item_path(bitstamp_item),
              frame: :modal
            ) %>
          <% end %>
          <% menu.with_item(
            variant: "button",
            text: t(".delete"),
            icon: "trash-2",
            href: bitstamp_item_path(bitstamp_item),
            method: :delete,
            confirm: CustomConfirm.for_resource_deletion(bitstamp_item.institution_display_name, high_severity: true)
          ) %>
        <% end %>
      </div>
    <% end %>

    <% unless bitstamp_item.scheduled_for_deletion? %>
      <div class="space-y-4 mt-4">
        <% if bitstamp_item.accounts.any? %>
          <%= render "accounts/index/account_groups", accounts: bitstamp_item.accounts %>
        <% end %>

        <% stats = bitstamp_item.syncs.ordered.first&.sync_stats || {} %>
        <%= render ProviderSyncSummary.new(stats: stats, provider_item: bitstamp_item) %>

        <% if unlinked_count.to_i > 0 && bitstamp_item.accounts.empty? %>
          <div class="p-4 flex flex-col gap-3 items-center justify-center">
            <p class="text-primary font-medium text-sm"><%= t(".setup_needed") %></p>
            <p class="text-secondary text-sm"><%= t(".setup_description") %></p>
            <%= render DS::Link.new(
              text: t(".setup_action"),
              icon: "plus",
              variant: "primary",
              href: setup_accounts_bitstamp_item_path(bitstamp_item),
              frame: :modal
            ) %>
          </div>
        <% elsif bitstamp_item.accounts.empty? && bitstamp_item.bitstamp_accounts.none? %>
          <div class="p-4 flex flex-col gap-3 items-center justify-center">
            <p class="text-primary font-medium text-sm"><%= t(".no_accounts_title") %></p>
            <p class="text-secondary text-sm"><%= t(".no_accounts_message") %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>