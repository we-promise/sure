<%# locals: (form:, entry:, candidates:, accounts:, scheduled_loan_payment_candidates: [], selected_method: nil, selected_target_account_id: nil, selected_scheduled_loan_account_id: nil, selected_matched_entry_id: nil) %>
<% scheduled_loan_payment_candidates = local_assigns[:scheduled_loan_payment_candidates] || [] %>
<% selected_method = local_assigns[:selected_method].presence || (scheduled_loan_payment_candidates.any? ? "scheduled_loan_payment" : candidates.any? ? "existing" : "new") %>
<% selected_target_account_id = local_assigns[:selected_target_account_id].presence %>
<% selected_scheduled_loan_account_id = local_assigns[:selected_scheduled_loan_account_id].presence %>
<% selected_matched_entry_id = local_assigns[:selected_matched_entry_id].presence %>
<% matching_methods = [] %>
<% matching_methods << [t(".match_scheduled_loan_payment_recommended"), "scheduled_loan_payment"] if scheduled_loan_payment_candidates.any? %>
<% matching_methods << [t(".match_existing_recommended"), "existing"] if candidates.any? %>
<% matching_methods << [t(".create_new_transaction"), "new"] %>

<% if candidates.any? || scheduled_loan_payment_candidates.any? %>
  <div data-controller="transfer-match" class="space-y-2">
    <p class="text-sm text-secondary">
      <%= t(".select_method") %>
    </p>

    <%= form.select :method,
              matching_methods,
              { selected: selected_method, label: t(".matching_method") },
              data: { action: "change->transfer-match#update" } %>

    <% if scheduled_loan_payment_candidates.any? %>
      <div data-transfer-match-target="scheduledLoanPaymentSelect" class="<%= "hidden" unless selected_method == "scheduled_loan_payment" %>">
        <%= form.select :scheduled_loan_account_id,
                  scheduled_loan_payment_candidates.map { |candidate|
                    account = candidate.fetch(:account)
                    split = candidate.fetch(:split)
                    label = t(
                      ".scheduled_loan_payment_option",
                      account: account.name,
                      due_date: format_date(split.due_date),
                      principal: format_money(Money.new(split.principal + split.extra_principal, account.currency)),
                      interest: format_money(Money.new(split.interest, account.currency))
                    )
                    [label, account.id]
                  },
                  { label: t(".scheduled_loan_payment"), selected: selected_scheduled_loan_account_id } %>
      </div>
    <% end %>

    <% if candidates.any? %>
      <div data-transfer-match-target="existingSelect" class="<%= "hidden" unless selected_method == "existing" %>">
        <%= form.select :matched_entry_id,
                  candidates.map { |entry|
                    [entry_name_detailed(entry), entry.id]
                  },
                  { label: t(".matching_transaction"), selected: selected_matched_entry_id } %>
      </div>
    <% end %>

    <div data-transfer-match-target="newSelect" class="<%= "hidden" unless selected_method == "new" %>">
      <%= form.select :target_account_id,
                accounts.map { |account| [account.name, account.id] },
                { label: t(".target_account"), selected: selected_target_account_id } %>
    </div>
  </div>
<% else %>
  <p class="text-sm text-secondary">
    <%= t(".no_matching_transactions") %>
  </p>

  <%= form.hidden_field :method, value: "new" %>

  <div>
    <%= form.select :target_account_id,
                accounts.map { |account| [account.name, account.id] },
                { label: t(".target_account"), selected: selected_target_account_id } %>
  </div>
<% end %>
