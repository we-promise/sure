{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sure",
  "version": "0.1.0",
  "identifier": "app.sure.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sure",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "prefs",
        "title": "Preferences",
        "width": 420,
        "height": 520,
        "visible": false,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "url": "prefs.html"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"],
    "category": "public.app-category.finance"
  },
  "plugins": {
    "deep-link": {
      "desktop": { "schemes": ["sure"] }
    }
  }
}
